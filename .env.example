# FastAPI runtime
HOST=0.0.0.0
PORT=8000

# Required: Massive (formerly Polygon) API key
MASSIVE_API_KEY=your-massive-api-key
# Optional compatibility alias for older local setups
# POLYGON_API_KEY=your-massive-api-key

# Demo mode: set to 1 to use bundled sample data (no API calls). Set to 0 to use live Massive data.
DEMO_MODE=1

# Optional: session signing secret (defaults to "change-me" if not set)
SESSION_SIGNER_SECRET=replace-with-unique-secret

# Optional: CORS allowlist (comma-separated origins). Leave empty to disable CORS.
# CORS_ALLOW_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
# CORS_ALLOW_CREDENTIALS=1

# Optional tuning knobs
SCANNER_CONCURRENCY=8
POLYGON_CONCURRENCY=8

# Enable unweighted fallback when all OI values are zero (0 or 1)
ALLOW_UNWEIGHTED_FALLBACK=0
